{
  "expo": {
    "name": "Univerin",
    "slug": "univerin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/univerin-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/univerin-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0fdfa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.univerin.app"
    },
    "android": {
      "package": "com.univerin.app",
      "adaptiveIcon": {
        "backgroundColor": "#0d9488",
        "foregroundImage": "./assets/univerin-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/univerin-icon.png"
    }
  }
}
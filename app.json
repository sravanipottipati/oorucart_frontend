{
  "expo": {
    "name": "Univerin",
    "slug": "univerin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1669ef"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.univerin.app"
    },
    "android": {
      "package": "com.univerin.app",
      "adaptiveIcon": {
        "backgroundColor": "#1669ef",
        "foregroundImage": "./assets/app-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/app-icon.png"
    }
  }
}
